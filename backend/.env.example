# Copie este arquivo para .env e preencha com os valores reais.
# .env nunca deve ser commitado (ja esta no .gitignore).

# Connection string do banco Postgres (Neon: copie em Dashboard > Connection string)
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/nomedobanco?sslmode=require

# Qualquer texto longo e aleatorio, usado pra assinar o login (token JWT).
# Gerar um novo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-um-valor-aleatorio-longo

# Porta local (Render define isso sozinho em producao)
PORT=3000
